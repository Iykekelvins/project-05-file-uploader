<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= folder.name %> - File Uploader</title>
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <div class="app-wrapper">

    <!-- HEADER -->
    <header class="topbar">

      <div class="welcome">
        <h2>📁 <%= folder.name %></h2>
        <p>Manage files inside this folder</p>
      </div>

      <div class="actions">
        <a class="btn secondary" href="/folders/<%= folder.id %>/upload">
          + Upload File
        </a>

        <a class="btn secondary" href="/">
          ← Back
        </a>
      </div>

    </header>

    <!-- CONTENT -->
    <main class="content">

      <% if (!files || files.length === 0) { %>

        <!-- EMPTY STATE -->
        <div class="empty-state">
          <h3>No files yet</h3>
          <p>Upload your first file into this folder.</p>

          <a class="btn primary" href="/folders/<%= folder.id %>/upload">
            Upload File
          </a>
        </div>

      <% } else { %>

        <!-- FILE GRID -->
        <div class="grid">

          <% files.forEach(file => { %>
            <div class="card">

              <div class="file-icon">📄</div>

              <div class="file-name">
                <%= file.name %>
              </div>

              <div class="file-meta">
                <small><%= file.path %></small>
              </div>

              <div class="file-actions">

                <a 
                  class="btn small secondary"
                  href="<%= file.path %>"
                  target="_blank"
                >
                  View
                </a>

                <!-- Optional delete -->
                <form 
                  action="/files/<%= file.id %>?_method=DELETE"
                  method="POST"
                >
                  <button class="btn small danger" type="submit">
                    Delete
                  </button>
                </form>

              </div>

            </div>
          <% }) %>

        </div>

      <% } %>

    </main>
  </div>
</body>
</html>